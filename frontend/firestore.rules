rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the document has the correct hallId scope
    function isDocumentOwner() {
      return isAuthenticated() && (resource == null || resource.data.hallId == request.auth.uid);
    }
    
    // Helper function to check if the user is the owner of the hall/settings doc
    function isOwner(hallId) {
      return isAuthenticated() && request.auth.uid == hallId;
    }

    // Halls are identified by their auth UID
    match /halls/{hallId} {
      allow read, write: if isOwner(hallId);
    }

    // Settings documents are identified by the authenticated user's UID
    match /settings/{hallId} {
      allow read, write: if isOwner(hallId);
    }

    // Scoped transactional collections
    match /occupants/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /seats/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /rooms/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /payments/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /attendanceSessions/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /tasks/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /expenses/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }

    match /notifications/{docId} {
      allow create: if isAuthenticated() && request.resource.data.hallId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.hallId == request.auth.uid && resource.data.hallId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.hallId == request.auth.uid;
    }
  }
}
