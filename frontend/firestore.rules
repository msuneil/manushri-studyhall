rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the document is owned by/scoped to the authenticated user
    function isOwner(hallId) {
      return isAuthenticated() && request.auth.uid == hallId;
    }

    // Halls are identified by their auth UID
    match /halls/{hallId} {
      allow read, write: if isOwner(hallId);
    }

    // Settings documents are identified by the authenticated user's UID
    match /settings/{hallId} {
      allow read, write: if isOwner(hallId);
    }

    // Standard scoped collections (occupants, seats, rooms, payments, attendanceSessions, tasks, expenses, notifications)
    match /{collection}/{docId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.hallId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.hallId == request.auth.uid
      );
    }
  }
}
